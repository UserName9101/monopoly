```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
*.coverage

# Temporary files
*.tmp
*.swp
*.swo

# Virtual environments
venv/
.venv/
.env/

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Distribution / packaging
.Python
*.egg-info/
.eggs/
.installed.cfg
*.egg

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```