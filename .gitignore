```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js
*.ts
*.tsx
*.jsx

# Logs and temp files
*.log
*.tmp
*.swp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Coverage reports
coverage/
htmlcov/
.coverage

# Testing
.pytest_cache/
.mypy_cache/

# OS generated files
.DS_Store
Thumbs.db
```